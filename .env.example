# Razbor — переменные окружения (раздел 16 ТЗ).
# Скопировать в .env на сервере и заполнить. В клиент НИЧЕГО, кроме NEXT_PUBLIC_*.
# .env в git НЕ коммитится.

# --- Supabase (доступ к БД только серверным service-ключом) ---
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# --- OpenAI: vision-аудит + встроенный веб-поиск (конкуренты) + мелочь на mini/nano ---
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-5.4
OPENAI_LIGHT_MODEL=gpt-5.4-mini

# --- Опционально: Perplexity Sonar как апгрейд веб-поиска ---
# PERPLEXITY_API_KEY=

# --- Google PageSpeed Insights ---
PAGESPEED_API_KEY=

# --- Unisender Go: транспорт почты (API-ключ) + подтверждённый отправитель ---
UNISENDER_GO_API_KEY=
UNISENDER_WEBHOOK_SECRET= # секрет для вебхуков статусов (?secret=...)
EMAIL_FROM=               # verified sender, напр. hello@getrazbor.ru
EMAIL_FROM_NAME=RAZBOR

# --- СМС-провайдер РФ (опционально, пока no-op) ---
SMS_API_KEY=

# --- Telegram-бот (выдача подарка) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=RazborAuditBot

# --- Подарок (чек-лист). Если пусто — APP_BASE_URL/gift/checklist.pdf ---
GIFT_URL=

# --- Контакт эксперта для CTA и follow-up ---
NEXT_PUBLIC_OWNER_CONTACT=https://t.me/arinashrr

# --- Cloudflare Turnstile (анти-бот) ---
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# --- Скрапер (локальный, тот же сервер) ---
SCRAPER_URL=http://localhost:8080
SCRAPER_KEY=
# Порт, на котором слушает scraper/server.ts
PORT=8080

# --- Базовый URL приложения ---
APP_BASE_URL=https://getrazbor.ru

# --- Закрытая /admin (баз-аут), раздел 14 ---
ADMIN_USER=
ADMIN_PASSWORD=
